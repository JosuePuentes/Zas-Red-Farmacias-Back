# MongoDB - Reemplaza con tu connection string completo
# Ejemplo: mongodb+srv://Zas:oIH7grtNjirgXCfV@cluster0.xxxxx.mongodb.net/zas_farmacias?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://Zas:TU_PASSWORD@cluster0.xxxxx.mongodb.net/zas_farmacias?retryWrites=true&w=majority

JWT_SECRET=tu_clave_secreta_jwt_muy_larga
PORT=4000

# Carpeta donde se guardan comprobantes, fotos, etc. (ruta absoluta o relativa a backend)
UPLOAD_DIR=./uploads

# Tasa BCV (Bolívares por USD). Si no hay valor en BD, se usa este.
# BCV_TASA=36

# Solo para npm run seed:master (crear primer usuario admin)
# MASTER_EMAIL=admin@zas.com
# MASTER_PASSWORD=admin123
